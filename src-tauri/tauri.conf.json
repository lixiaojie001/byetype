{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri2-json-schema/refs/heads/main/schemas/2.x.x/tauri-config.schema.json",
  "productName": "ByeType",
  "version": "1.3.1",
  "identifier": "com.byetype.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "ByeType Settings",
        "width": 780,
        "height": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "prompts/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "exceptionDomain": ""
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese", "English"]
      }
    },
    "publisher": "ByeType",
    "category": "Utility",
    "shortDescription": "Markdown-driven voice input powered by AI"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3REI2REU4RDJDMjk3RDgKUldUWWw4TFM2RzNicDhlR3luOWI1c3d3TUsyK2tOZk1QcFZ6V2JBWS85UnJpdU9sVlJYRjlNVFcK",
      "endpoints": [
        "https://github.com/lixiaojie001/byetype/releases/latest/download/latest.json"
      ]
    }
  }
}
